---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const capabilities = [
	['ops', 'Cloud Phone Environment Management', 'Independent cloud environments for accounts, with unified device and network configuration.'],
	['platform', 'Bulk Accounts and Proxies', 'Static, dynamic, and mobile proxies assigned across organized account groups.'],
	['product', 'AI Content Operations', 'Generate copy and tags in multiple styles while keeping assets organized in one library.'],
	['insights', 'Automated Task Center', 'Run login, warming, and publishing tasks in batches with traceable execution records.'],
];
const audiences = [
	['ops', 'Cross-Border Sellers', 'Each market needs accounts, devices, timing, and content. Ainnc helps teams run accounts in independent cloud environments and organize publishing by target market.'],
	['platform', 'MCNs and Agencies', 'As signed accounts grow, maintenance and scheduling become expensive. Bulk assets, task queues, and shared dashboards keep repetitive work inside the system.'],
	['insights', 'Global Brand Teams', 'When teams lack local staff, local content, or devices, Ainnc gives them a structured workflow for accounts, content, publishing, and review.'],
	['product', 'Why Infrastructure', 'Accounts, proxies, assets, and tasks share one record system instead of living across sheets, drives, and chat threads. Scale should not make the workflow messy.'],
];
const proofStats = [
	['3', '+', 'years of social ops'],
	['10000', '+', 'managed account environments'],
	['4', '', 'major social platforms'],
	['7', 'x24', 'cloud automation runtime'],
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About Ainnc" description="Ainnc is social operations infrastructure for teams managing accounts, proxies, assets, and publishing tasks at scale." />
	</head>
	<body class="about-page">
		<Header />
		<img class="page-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
		<main>
			<section class="about-hero" id="about-hero">
				<div class="hero-copy">
					<span class="section-kicker">ABOUT AINNC</span>
					<h1>Social Operations <span class="hero-accent">Infrastructure</span><br />{' '}for Global Teams</h1>
					<p>
						Ainnc is not just a posting tool. It is an operating layer where accounts,
						proxies, assets, and tasks share the same system for teams managing social accounts at scale.
					</p>
				</div>
				<div class="proof-panel" aria-label="Ainnc operating scale">
					<div class="proof-head">
						<span>Ainnc · Operating Scale</span>
						<em>TRACK RECORD</em>
					</div>
					<div class="proof-grid">
						{
							proofStats.map(([value, suffix, label]) => (
								<div class="proof-cell">
									<strong class="count-up" data-count={value} data-suffix={suffix}>0{suffix}</strong>
									<span>{label}</span>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="about-detail-section" aria-label="Ainnc audiences and product capabilities">
				<div class="audience-grid" data-audience-reveal>
					{
						audiences.map(([tone, title, description]) => (
							<article class="audience-item" data-tone={tone}>
								<h2>{title}</h2>
								<p>{description}</p>
							</article>
						))
					}
				</div>

				<div class="capability-shell" data-capability-reveal>
					<div class="capability-header">
						<div class="capability-title">
							<span class="eyebrow">Product Capabilities</span>
							<h2>One Console From Account Management to Publishing</h2>
						</div>
						<p>Built for scaled operations across TikTok, Instagram, Reddit, X, and similar platforms.</p>
					</div>
					<div class="capability-grid">
						{
							capabilities.map(([tone, title, description]) => (
								<article class="capability-item" data-tone={tone}>
									<h3>{title}</h3>
									<p>{description}</p>
								</article>
							))
						}
					</div>
					<div class="detail-stats" aria-label="Ainnc overview">
						<div class="detail-stat">
							<strong class="detail-stat-number" data-detail-count="4" data-duration="700">0</strong>
							<span>covered platforms</span>
						</div>
						<div class="detail-stat">
							<strong class="detail-stat-number" data-detail-count="3" data-duration="600">0</strong>
							<span>core scenarios</span>
						</div>
						<div class="detail-stat">
							<strong class="detail-stat-number accent" data-detail-count="1" data-duration="500" data-pad="2">00</strong>
							<span>unified console</span>
						</div>
					</div>
				</div>
			</section>

			<a class="blog-cta" href="/en/blog/">
				<span>READ MORE / BLOG</span>
				<strong>Read Practical Playbooks for Agency-Scale Social Operations</strong>
				<em>View all articles -&gt;</em>
			</a>
		</main>
		<Footer />
		<script>
			const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const counters = document.querySelectorAll<HTMLElement>('.count-up');

			const finishCounter = (counter: HTMLElement) => {
				counter.textContent = `${counter.dataset.count ?? '0'}${counter.dataset.suffix ?? ''}`;
			};

			const animateCounter = (counter: HTMLElement) => {
				const target = Number(counter.dataset.count ?? 0);
				const suffix = counter.dataset.suffix ?? '';
				const duration = 1400;
				const start = performance.now();

				const tick = (now: number) => {
					const progress = Math.min(1, (now - start) / duration);
					const eased = 1 - Math.pow(1 - progress, 3);
					counter.textContent = `${Math.round(target * eased)}${suffix}`;

					if (progress < 1) {
						window.requestAnimationFrame(tick);
					} else {
						finishCounter(counter);
					}
				};

				window.requestAnimationFrame(tick);
			};

			if (reducedMotion || !('IntersectionObserver' in window)) {
				counters.forEach(finishCounter);
			} else {
				const counterObserver = new IntersectionObserver(
					(entries, observer) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							const counter = entry.target as HTMLElement;
							animateCounter(counter);
							observer.unobserve(counter);
						});
					},
					{ threshold: 0.45 },
				);

				counters.forEach((counter) => counterObserver.observe(counter));
			}

			const detailSection = document.querySelector<HTMLElement>('.about-detail-section');
			const audienceGroup = document.querySelector<HTMLElement>('[data-audience-reveal]');
			const capabilityGroup = document.querySelector<HTMLElement>('[data-capability-reveal]');
			const audienceItems = Array.from(document.querySelectorAll<HTMLElement>('.audience-item'));
			const capabilityItems = Array.from(document.querySelectorAll<HTMLElement>('.capability-item'));
			const detailCounters = Array.from(document.querySelectorAll<HTMLElement>('.detail-stat-number'));

			const formatDetailValue = (value: number, pad: number) => String(value).padStart(pad, '0');
			const finishDetailCounter = (counter: HTMLElement) => {
				const target = Number(counter.dataset.detailCount ?? 0);
				const pad = Number(counter.dataset.pad ?? 1);
				counter.textContent = formatDetailValue(target, pad);
			};
			const animateDetailCounter = (counter: HTMLElement) => {
				if (counter.dataset.counted === 'true') return;
				counter.dataset.counted = 'true';
				const target = Number(counter.dataset.detailCount ?? 0);
				const duration = Number(counter.dataset.duration ?? 600);
				const pad = Number(counter.dataset.pad ?? 1);
				const start = performance.now();

				const tick = (now: number) => {
					const progress = Math.min(1, (now - start) / duration);
					const eased = 1 - Math.pow(1 - progress, 3);
					counter.textContent = formatDetailValue(Math.round(target * eased), pad);
					if (progress < 1) window.requestAnimationFrame(tick);
				};

				window.requestAnimationFrame(tick);
			};
			const revealSequence = (items: HTMLElement[], delays: number[]) => {
				items.forEach((item, index) => {
					const delay = delays[index] ?? 0;
					window.setTimeout(() => {
						item.classList.add('is-visible');
						window.setTimeout(() => item.classList.add('reveal-complete'), 560);
					}, delay);
				});
			};

			if (reducedMotion || !('IntersectionObserver' in window)) {
				detailCounters.forEach(finishDetailCounter);
			} else if (detailSection) {
				detailSection.classList.add('motion-ready');
				if (audienceGroup) {
					const audienceObserver = new IntersectionObserver(
						(entries, observer) => {
							if (!entries.some((entry) => entry.isIntersecting)) return;
							revealSequence(audienceItems, [50, 150, 250, 350]);
							observer.disconnect();
						},
						{ threshold: 0.18 },
					);
					audienceObserver.observe(audienceGroup);
				}
				if (capabilityGroup) {
					const capabilityObserver = new IntersectionObserver(
						(entries, observer) => {
							if (!entries.some((entry) => entry.isIntersecting)) return;
							revealSequence(capabilityItems, [100, 220, 340, 460]);
							detailCounters.forEach(animateDetailCounter);
							observer.disconnect();
						},
						{ threshold: 0.2 },
					);
					capabilityObserver.observe(capabilityGroup);
				}
			}
		</script>
	</body>
</html>

<style>
	.capability-item {
		--item-accent: var(--tone-ops);
	}

	.capability-item[data-tone='platform'] {
		--item-accent: var(--tone-platform);
	}

	.capability-item[data-tone='product'] {
		--item-accent: var(--tone-product);
	}

	.capability-item[data-tone='insights'] {
		--item-accent: var(--tone-insights);
	}

	.capability-shell {
		border-radius: 24px;
		background: white;
		padding: 48px 44px;
		box-shadow: 0 4px 24px rgba(6, 39, 42, 6%);
	}

	.capability-header {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 36px;
	}

	.capability-title {
		display: grid;
		gap: 14px;
	}

	.capability-title h2 {
		max-width: 680px;
		font-size: 26px;
		font-weight: 900;
		line-height: 1.2;
	}

	.capability-header p {
		max-width: 280px;
		color: #5b6e6c;
		font-size: 13px;
		line-height: 1.7;
	}

	.capability-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 20px;
		margin-bottom: 36px;
	}

	.capability-item {
		position: relative;
		margin: 0 -14px;
		border-radius: 12px;
		padding: 18px 14px 14px;
		cursor: pointer;
		transition:
			background 0.25s ease,
			box-shadow 0.25s ease,
			transform 0.25s ease;
	}

	.capability-item::before {
		content: '';
		position: absolute;
		top: 0;
		right: 14px;
		left: 14px;
		height: 2px;
		background: var(--item-accent);
		transform: scaleX(1);
		transform-origin: left;
		transition: transform 0.25s ease;
	}

	.capability-item:hover {
		background: #f5fcfb;
		box-shadow: 0 12px 24px rgba(6, 39, 42, 8%);
		transform: translateY(-4px);
	}

	.capability-item:hover::before {
		transform: scaleX(1.15);
	}

	.capability-item h3 {
		font-size: 15px;
		font-weight: 700;
	}

	.capability-item p {
		margin-top: 8px;
		color: #5b6e6c;
		font-size: 12px;
		line-height: 1.6;
	}

	.detail-stats {
		display: flex;
		align-items: center;
		border-top: 1px solid #eef6f4;
		padding-top: 24px;
	}

	.detail-stat {
		display: flex;
		align-items: baseline;
		gap: 6px;
		border-right: 1px solid #eef6f4;
		padding: 0 32px;
	}

	.detail-stat:first-child {
		padding-left: 0;
	}

	.detail-stat:last-child {
		border-right: 0;
		padding-right: 0;
	}

	.detail-stat-number {
		display: inline-block;
		color: #06272a;
		font-family: 'Space Grotesk', sans-serif;
		font-size: 22px;
		font-weight: 700;
		line-height: 1;
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.detail-stat-number.accent {
		color: #00b1b3;
	}

	.detail-stat span {
		color: #7a8e8b;
		font-size: 12px;
	}

	.detail-stat:hover .detail-stat-number {
		color: #00b1b3;
		transform: translateY(-2px);
	}

	.motion-ready .audience-item,
	.motion-ready .capability-item {
		opacity: 0;
		transform: translateY(12px);
	}

	.motion-ready .audience-item.is-visible,
	.motion-ready .capability-item.is-visible {
		animation: detail-fade-up 0.55s ease forwards;
	}

	.motion-ready .audience-item.reveal-complete,
	.motion-ready .capability-item.reveal-complete {
		opacity: 1;
		transform: none;
		animation: none;
	}

	.motion-ready .capability-item::before {
		transform: scaleX(0);
		transition-duration: 0.9s;
		transition-timing-function: ease-out;
	}

	.motion-ready .capability-item.is-visible::before {
		transform: scaleX(1);
	}

	.motion-ready .audience-item.reveal-complete:hover {
		transform: translateX(4px);
	}

	.motion-ready .capability-item.reveal-complete:hover {
		transform: translateY(-4px);
	}

	.motion-ready .capability-item.reveal-complete:hover::before {
		transform: scaleX(1.15);
	}

	@keyframes detail-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.blog-cta {
		position: relative;
		display: grid;
		gap: 0.75rem;
		overflow: hidden;
		margin-bottom: 2rem;
		border-radius: 8px;
		background: linear-gradient(135deg, #04302e, #06403c 55%, #0a5049);
		padding: 2rem;
		color: white;
		text-decoration: none;
	}

	.blog-cta::before {
		content: '';
		position: absolute;
		top: -8rem;
		right: -4rem;
		width: 22rem;
		height: 22rem;
		border-radius: 999px;
		background: radial-gradient(circle, rgba(46, 233, 208, 28%), transparent 70%);
	}

	.blog-cta span,
	.blog-cta strong,
	.blog-cta em {
		position: relative;
		z-index: 1;
	}

	.blog-cta span {
		color: var(--accent);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.blog-cta strong {
		max-width: 720px;
		font-size: clamp(1.55rem, 3vw, 2rem);
	}

	.blog-cta em {
		color: #b8eee7;
		font-style: normal;
		font-weight: 900;
	}

	@media (max-width: 900px) {
		.capability-header {
			align-items: flex-start;
			gap: 12px;
		}

		.capability-header p {
			max-width: 100%;
		}

		.capability-shell {
			padding: 36px 28px;
		}

		.capability-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 24px 20px;
		}

		.detail-stat {
			padding: 0 18px;
		}
	}

	@media (max-width: 620px) {
		.capability-shell {
			padding: 28px 20px;
		}

		.capability-title h2 {
			font-size: 23px;
		}

		.capability-grid {
			grid-template-columns: 1fr;
		}

		.detail-stats {
			display: grid;
			grid-template-columns: 1fr;
			padding-top: 10px;
		}

		.detail-stat,
		.detail-stat:first-child,
		.detail-stat:last-child {
			border-right: 0;
			border-bottom: 1px solid #eef6f4;
			padding: 14px 0;
		}

		.detail-stat:last-child {
			border-bottom: 0;
		}
	}
	/* About unframed layout */
	:global(html) {
		overflow-x: clip;
	}

	.about-page {
		position: relative;
		overflow-x: hidden;
	}

	main {
		position: relative;
		z-index: 1;
		width: min(1240px, calc(100% - 5.5rem));
		padding: 0 0 2.5rem;
	}

	.page-watermark {
		position: absolute;
		top: 88px;
		right: -60px;
		z-index: 0;
		width: min(520px, 42vw);
		border-radius: 0;
		opacity: 0.05;
		filter: grayscale(1) brightness(0.45);
		pointer-events: none;
		user-select: none;
	}

	.about-hero {
		display: block;
		min-height: auto;
		overflow: visible;
		margin-bottom: 0;
		border: 0;
		border-radius: 0;
		background: none;
		padding: 110px 0 0;
		box-shadow: none;
		text-align: center;
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		display: grid;
		max-width: 900px;
		margin: 0 auto;
		gap: 0;
		padding: 0;
		justify-items: center;
	}

	.section-kicker {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		width: fit-content;
		color: var(--accent-dark);
		font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12.5px;
		font-weight: 500;
		letter-spacing: 0.2em;
	}

	.section-kicker::before,
	.section-kicker::after {
		content: '';
		width: 26px;
		height: 1px;
		background: var(--accent-dark);
	}

	.hero-copy h1 {
		margin-top: 26px;
		font-size: clamp(36px, 4.6vw, 60px);
		font-weight: 900;
		letter-spacing: 0.01em;
		line-height: 1.3;
	}

	.hero-accent {
		background: linear-gradient(92deg, var(--accent-dark) 10%, var(--accent) 90%);
		background-clip: text;
		color: transparent;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.hero-copy p {
		max-width: 42em;
		margin-top: 26px;
		color: var(--muted);
		font-size: 16px;
		line-height: 2;
	}

	.proof-panel {
		position: relative;
		z-index: 1;
		width: min(1000px, 100%);
		overflow: hidden;
		margin: 54px auto 0;
		border: 1px solid color-mix(in srgb, var(--surface) 9%, transparent);
		border-radius: 16px;
		background: linear-gradient(
			160deg,
			color-mix(in srgb, var(--text) 88%, var(--muted)),
			color-mix(in srgb, var(--text) 88%, black)
		);
		padding: 26px 28px 28px;
		box-shadow: 0 34px 70px -34px color-mix(in srgb, var(--accent-dark) 50%, transparent);
		color: color-mix(in srgb, var(--surface) 92%, var(--accent));
		text-align: left;
		backdrop-filter: none;
	}

	.proof-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 20px;
		color: color-mix(in srgb, var(--surface) 92%, var(--accent));
	}

	.proof-head span,
	.proof-head em,
	.proof-cell strong {
		font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
	}

	.proof-head span {
		font-size: 14.5px;
		font-weight: 700;
	}

	.proof-head em {
		border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
		border-radius: 999px;
		background: transparent;
		padding: 6px 14px;
		color: var(--accent);
		font-size: 11.5px;
		font-style: normal;
		font-weight: 500;
		letter-spacing: 0.16em;
	}

	.proof-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 12px;
	}

	.proof-cell {
		border: 1px solid color-mix(in srgb, var(--surface) 9%, transparent);
		border-radius: 11px;
		background: color-mix(in srgb, var(--surface) 5%, transparent);
		padding: 18px 20px;
	}

	.proof-cell strong,
	.proof-cell span {
		display: block;
	}

	.proof-cell strong {
		background: linear-gradient(92deg, color-mix(in srgb, var(--surface) 92%, var(--accent)), color-mix(in srgb, var(--accent) 46%, var(--surface)));
		background-clip: text;
		color: transparent;
		font-size: 28px;
		font-weight: 600;
		letter-spacing: 0.02em;
		line-height: 1;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.proof-cell span {
		margin-top: 6px;
		color: color-mix(in srgb, var(--surface) 48%, var(--muted));
		font-size: 13px;
		font-weight: 500;
	}

	.about-detail-section {
		margin-top: 90px;
		margin-bottom: 2rem;
	}

	.audience-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0 72px;
		margin-bottom: 90px;
		border-top: 1px solid var(--line);
	}

	.audience-item {
		margin-left: 0;
		border-bottom: 1px solid var(--line);
		border-radius: 0;
		background: transparent;
		padding: 34px 0;
		cursor: default;
		transition: none;
	}

	.audience-item::before {
		content: none;
	}

	.audience-item:hover,
	.motion-ready .audience-item.reveal-complete:hover {
		background: transparent;
		transform: none;
	}

	.audience-item h2 {
		display: flex;
		align-items: center;
		gap: 12px;
		font-size: 16.5px;
		font-weight: 700;
	}

	.audience-item h2::before {
		content: '';
		width: 8px;
		height: 8px;
		flex: 0 0 auto;
		border-radius: 2px;
		background: var(--accent-dark);
	}

	.audience-item p {
		margin-top: 12px;
		color: var(--muted);
		font-size: 14px;
		line-height: 2;
	}

	@media (max-width: 900px) {
		main {
			width: calc(100% - 2.5rem);
		}

		.page-watermark {
			right: -100px;
			width: min(430px, 70vw);
