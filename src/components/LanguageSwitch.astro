---
import { localizedPath } from '../i18n';

const currentPath = Astro.url.pathname;
const zhPath = localizedPath(currentPath, 'zh');
const enPath = localizedPath(currentPath, 'en');
const isEnglish = currentPath === '/en' || currentPath.startsWith('/en/');
---

<div class="language-switch" aria-label="Language switcher">
	<a class:list={[{ active: !isEnglish }]} href={zhPath}>中文</a>
	<a class:list={[{ active: isEnglish }]} href={enPath}>EN</a>
</div>

<style>
	.language-switch {
		display: inline-flex;
		align-items: center;
		gap: 0.9rem;
	}

	a {
		display: inline-flex;
		min-width: 3.2rem;
		min-height: 3.2rem;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 255, 255, 82%);
		padding: 0.55rem 0.75rem;
		color: var(--muted);
		font-size: 1rem;
		font-weight: 800;
		text-decoration: none;
		white-space: nowrap;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 88%);
		transition:
			border-color 0.18s ease,
			box-shadow 0.18s ease,
			color 0.18s ease,
			transform 0.18s ease;
	}

	a.active {
		border-color: #00aeb0;
		background: #f8fffd;
		color: var(--accent);
		box-shadow:
			0 10px 24px rgba(0, 201, 170, 10%),
			inset 0 1px 0 rgba(255, 255, 255, 90%);
	}

	a:hover {
		border-color: #61e8dd;
		color: var(--accent-dark);
		transform: translateY(-1px);
	}
</style>
