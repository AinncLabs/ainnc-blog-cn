---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCategoryTone, getPostCode } from '../blogVisuals';
import type { Locale } from '../i18n';
import { getScenarioModule } from '../scenarioModules';

type Props = CollectionEntry<'blog'>['data'] & {
	locale?: Locale;
	postIndex?: number;
	postId?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	category = 'Ainnc',
	tags = [],
	locale = 'zh',
	postIndex = 0,
	postId,
} = Astro.props;
const isEnglish = locale === 'en';
const tagLabel = isEnglish ? 'Post tags' : '文章标签';
const blogPath = isEnglish ? '/en/blog/' : '/blog/';
const backLabel = isEnglish ? 'Back to Blog' : '返回博客列表';
const ctaTitle = isEnglish ? 'Run Your Social Account Matrix From One Platform' : '用一个平台运营你的整个社媒矩阵';
const ctaDescription = isEnglish
	? 'See how Ainnc handles account isolation, proxy IPs, content assets, and bulk publishing for scaled operations.'
	: '看看 Ainnc 如何在规模化场景下处理账号隔离、代理 IP、素材管理和批量发布。';
const officialLabel = isEnglish ? 'Visit Official Site' : '访问官网';
const telegramLabel = isEnglish ? 'Contact on Telegram' : 'Telegram 咨询';
const categoryTone = getCategoryTone(category);
const postCode = getPostCode(category, postIndex);
const scenario = getScenarioModule(postId, locale);
const scenarioTitle = isEnglish ? 'Scenario Reading' : '场景化阅读';
const scenarioIntro = isEnglish
	? 'Read this article through the actual work context, the operational problem, and how Ainnc helps.'
	: '先把这篇文章放进真实工作里看：什么场景、什么问题、Ainnc 能怎么帮。';
const scenarioItems = isEnglish
	? [
			['Scenario', scenario.scene],
			['Problem', scenario.problem],
			['Ainnc Provides', scenario.solution],
			['Result', scenario.outcome],
		]
	: [
			['适用场景', scenario.scene],
			['典型问题', scenario.problem],
			['Ainnc 能提供什么', scenario.solution],
			['预期结果', scenario.outcome],
		];
---

<html lang={isEnglish ? 'en' : 'zh-CN'}>
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
		<Header />
		<main>
			<a class="back-link" href={blogPath}><span aria-hidden="true">&larr;</span>{backLabel}</a>
			<article class="article-shell" data-tone={categoryTone}>
				<header class="article-header">
					<div class="article-code">
						<span>ARTICLE</span>
						<span aria-hidden="true">/</span>
						<span>{postCode}</span>
					</div>
					<div class="post-meta">
						<span>{category}</span>
						<span><FormattedDate date={pubDate} locale={locale} /></span>
						{
							updatedDate && (
								<span>
									{isEnglish ? 'Updated ' : '更新于 '}
									<FormattedDate date={updatedDate} locale={locale} />
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
					{
						tags.length > 0 && (
							<ul class="tag-list" aria-label={tagLabel}>
								{tags.map((tag) => (
									<li>{tag}</li>
								))}
							</ul>
						)
					}
				</header>

				<section class="scenario-panel panel" aria-labelledby="scenario-title">
					<div class="scenario-head">
						<div>
							<span>{scenarioTitle}</span>
							<h2 id="scenario-title">{isEnglish ? 'Start From the Use Case' : '先看这篇适合谁读'}</h2>
						</div>
						<p>{scenarioIntro}</p>
					</div>
					<div class="scenario-grid">
						{
							scenarioItems.map(([label, text], index) => (
								<div class="scenario-card">
									<span class="scenario-index">{String(index + 1).padStart(2, '0')}</span>
									<h3>{label}</h3>
									<p>{text}</p>
								</div>
							))
						}
					</div>
				</section>

				<div class="prose panel">
					<slot />
				</div>

				<section class="article-cta">
					<h2>{ctaTitle}</h2>
					<p>{ctaDescription}</p>
					<div class="cta-actions">
						<a href="https://www.ainnc.com/#hero" target="_blank" rel="noopener noreferrer">
							{officialLabel}
						</a>
						<a class="secondary-cta" href="https://t.me/qccbot2026" target="_blank" rel="noopener noreferrer">
							{telegramLabel}
						</a>
					</div>
				</section>
			</article>
		</main>
		<button class="back-to-top" type="button" id="back-to-top" aria-label={isEnglish ? 'Back to top' : '返回顶部'}>
			&uarr;
		</button>
		<Footer />
		<script>
			const progress = document.getElementById('reading-progress');
			const backToTop = document.getElementById('back-to-top');

			function updateReadingState() {
				const scrollable = document.documentElement.scrollHeight - window.innerHeight;
				const percent = scrollable > 0 ? Math.min(100, (window.scrollY / scrollable) * 100) : 0;
				if (progress) {
					progress.style.width = `${percent}%`;
				}
				if (backToTop) {
					backToTop.classList.toggle('show', window.scrollY > 520);
				}
			}

			window.addEventListener('scroll', updateReadingState, { passive: true });
			updateReadingState();
			backToTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

			const revealItems = document.querySelectorAll('.prose > *');
			if ('IntersectionObserver' in window) {
				const revealObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							entry.target.classList.add('is-visible');
							revealObserver.unobserve(entry.target);
						});
					},
					{ rootMargin: '0px 0px -10% 0px', threshold: 0.12 },
				);

				revealItems.forEach((item) => {
					item.classList.add('reveal-item');
					revealObserver.observe(item);
				});
			} else {
				revealItems.forEach((item) => item.classList.add('is-visible'));
			}
		</script>
	</body>
</html>

<style>
	.reading-progress {
		position: fixed;
		z-index: 30;
		top: 0;
		left: 0;
		width: 0;
		height: 3px;
		background: linear-gradient(90deg, var(--accent-dark), var(--accent));
	}

	.back-link {
		display: inline-flex;
		gap: 0.35rem;
		align-items: center;
		margin-bottom: 1rem;
		color: var(--muted);
		font-weight: 800;
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--accent-dark);
	}

	.article-shell {
		--article-accent: var(--accent-dark);
		--article-accent-soft: var(--surface-blue);
		display: grid;
		gap: 1rem;
		justify-items: center;
	}

	.article-shell[data-tone='ops'] {
		--article-accent: var(--tone-ops);
		--article-accent-soft: #e3fbf7;
	}

	.article-shell[data-tone='product'] {
		--article-accent: var(--tone-product);
		--article-accent-soft: #e1f5fb;
	}

	.article-shell[data-tone='platform'] {
		--article-accent: var(--tone-platform);
		--article-accent-soft: #e7eef6;
	}

	.article-shell[data-tone='insights'] {
		--article-accent: var(--tone-insights);
		--article-accent-soft: #e2f7ee;
	}

	.article-header {
		display: grid;
		width: min(780px, 100%);
		gap: 1rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: white;
		padding: 2rem;
		box-shadow: var(--shadow);
	}

	.article-code {
		display: inline-flex;
		gap: 0.5rem;
		align-items: center;
		width: fit-content;
		border: 1px solid color-mix(in srgb, var(--article-accent) 26%, white);
		border-radius: 999px;
		background: var(--article-accent-soft);
		padding: 0.28rem 0.7rem;
		color: var(--article-accent);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.8rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.article-header p {
		max-width: 760px;
		font-size: 1.05rem;
	}

	.scenario-panel {
		display: grid;
		width: min(780px, 100%);
		gap: 1.25rem;
		margin: 0 auto;
		padding: 1.4rem;
		border-top: 4px solid var(--article-accent);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 94%), rgba(232, 255, 251, 92%)),
			radial-gradient(circle at 12% 18%, color-mix(in srgb, var(--article-accent) 16%, transparent), transparent 28%);
	}

	.scenario-head {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(220px, 1fr);
		gap: 1rem;
		align-items: end;
	}

	.scenario-head span {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 0.45rem;
		border: 1px solid color-mix(in srgb, var(--article-accent) 32%, white);
		border-radius: 999px;
		background: var(--article-accent-soft);
		padding: 0.25rem 0.6rem;
		color: var(--article-accent);
		font-size: 0.78rem;
		font-weight: 900;
	}

	.scenario-head h2 {
		margin: 0;
		font-size: clamp(1.35rem, 3vw, 2rem);
	}

	.scenario-head p {
		margin: 0;
		color: var(--muted);
		font-weight: 800;
		line-height: 1.75;
	}

	.scenario-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.scenario-card {
		position: relative;
		min-height: 11rem;
		border: 1px solid color-mix(in srgb, var(--article-accent) 20%, white);
		border-radius: 8px;
		background: rgba(255, 255, 255, 74%);
		padding: 1rem;
		overflow: hidden;
	}

	.scenario-card::after {
		content: '';
		position: absolute;
		right: -1.8rem;
		bottom: -1.8rem;
		width: 5rem;
		height: 5rem;
		border: 1px solid color-mix(in srgb, var(--article-accent) 24%, transparent);
		border-radius: 999px;
	}

	.scenario-index {
		display: inline-flex;
		margin-bottom: 0.8rem;
		border-radius: 999px;
		background: #052f2d;
		padding: 0.22rem 0.5rem;
		color: white;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.72rem;
		font-weight: 900;
	}

	.scenario-card h3 {
		margin: 0 0 0.5rem;
		font-size: 1.02rem;
	}

	.scenario-card p {
		margin: 0;
		color: var(--muted);
		font-size: 0.95rem;
		line-height: 1.72;
	}

	.prose {
		width: min(780px, 100%);
		margin: 0 auto;
		padding: 2rem;
		font-size: 1.04rem;
	}

	.prose :global(.reveal-item) {
		opacity: 0;
		transform: translateY(14px);
		transition:
			opacity 0.55s ease,
			transform 0.55s ease;
	}

	.prose :global(.reveal-item.is-visible) {
		opacity: 1;
		transform: translateY(0);
	}

	.prose :global(h2),
	.prose :global(h3) {
		position: relative;
		padding-left: 1.1rem;
	}

	.prose :global(h2::before),
	.prose :global(h3::before) {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55em;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 2px;
		background: var(--article-accent);
		transform: rotate(45deg);
	}

	.article-cta {
		display: grid;
		gap: 1rem;
		width: min(780px, 100%);
		margin: 0 auto;
		border-radius: 8px;
		background: linear-gradient(135deg, #04302e, #06544f);
		padding: 2rem;
		color: white;
	}

	.article-cta h2,
	.article-cta p {
		color: white;
	}

	.article-cta p {
		max-width: 620px;
		color: #b8eee7;
	}

	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.cta-actions a {
		border-radius: 8px;
		background: var(--accent);
		padding: 0.7rem 1rem;
		color: #032726;
		font-weight: 900;
		text-decoration: none;
	}

	.cta-actions a:hover {
		background: white;
		color: #032726;
	}

	.cta-actions .secondary-cta {
		border: 1px solid rgba(184, 238, 231, 60%);
		background: transparent;
		color: white;
	}

	.back-to-top {
		position: fixed;
		right: 1.25rem;
		bottom: 1.25rem;
		z-index: 20;
		display: grid;
		width: 2.75rem;
		height: 2.75rem;
		place-items: center;
		border: 0;
		border-radius: 999px;
		background: #063f3c;
		color: white;
		font: inherit;
		font-weight: 900;
		box-shadow: var(--shadow);
		cursor: pointer;
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
	}

	.back-to-top.show {
		opacity: 1;
		pointer-events: auto;
	}

	.back-to-top:hover {
		transform: translateY(-3px);
		background: var(--accent-dark);
	}

	@media (max-width: 720px) {
		.article-header,
		.scenario-panel,
		.prose,
		.article-cta {
			padding: 1rem;
		}

		.scenario-head,
		.scenario-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.prose :global(.reveal-item) {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>
