---
import { getEnglishSections } from '../i18n';

interface Props {
	postId: string;
}

const { postId } = Astro.props;
const sections = getEnglishSections(postId);
---

{
	sections.map((section) => (
		<section>
			{section.heading && <h2>{section.heading}</h2>}
			{section.paragraphs.map((paragraph) => (
				<p>{paragraph}</p>
			))}
		</section>
	))
}
