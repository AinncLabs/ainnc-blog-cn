---
import { localizedPath } from '../i18n';

const currentPath = Astro.url.pathname;
const zhPath = localizedPath(currentPath, 'zh');
const enPath = localizedPath(currentPath, 'en');
const isEnglish = currentPath === '/en' || currentPath.startsWith('/en/');
---

<div class:list={['language-switch', { english: isEnglish }]} aria-label="Language switcher">
	<a class:list={[{ active: !isEnglish }]} href={zhPath}>中文</a>
	<a class:list={[{ active: isEnglish }]} href={enPath}>EN</a>
</div>

<style>
	.language-switch {
		position: relative;
		display: inline-flex;
		align-items: center;
		width: 5.95rem;
		height: 2.65rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 82%), rgba(245, 255, 252, 78%)),
			rgba(255, 255, 255, 78%);
		padding: 0.2rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 90%),
			0 10px 22px rgba(0, 201, 170, 8%);
		overflow: hidden;
	}

	.language-switch::before {
		content: '';
		position: absolute;
		top: 0.2rem;
		left: 0.2rem;
		width: calc(50% - 0.2rem);
		height: calc(100% - 0.4rem);
		border: 1px solid rgba(97, 232, 221, 54%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 94%);
		box-shadow:
			0 10px 22px rgba(0, 201, 170, 14%),
			inset 0 1px 0 rgba(255, 255, 255, 96%);
		transition: transform 0.26s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.language-switch.english::before {
		transform: translateX(100%);
	}

	a {
		position: relative;
		z-index: 1;
		flex: 1 1 0;
		min-width: 0;
		display: inline-flex;
		height: 100%;
		align-items: center;
		justify-content: center;
		color: var(--muted);
		font-size: 0.9rem;
		font-weight: 800;
		text-decoration: none;
		white-space: nowrap;
		transition:
			color 0.18s ease,
			transform 0.18s ease;
	}

	a.active {
		color: var(--accent);
	}

	a:hover {
		color: var(--accent-dark);
	}
</style>
