---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname =
	basePath && Astro.url.pathname.startsWith(basePath)
		? Astro.url.pathname.slice(basePath.length) || '/'
		: Astro.url.pathname;
const normalizedHref = href?.toString().replace(/\/$/, '') || '/';
const normalizedPath = pathname.replace(/\/$/, '') || '/';
const exactOnly = normalizedHref === '/' || normalizedHref === '/en';
const isActive = exactOnly
	? normalizedPath === normalizedHref
	: normalizedPath === normalizedHref || normalizedPath.startsWith(`${normalizedHref}/`);
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		position: relative;
		display: inline-flex;
		align-items: center;
		border-radius: 0;
		padding: 0.4rem 0.18rem 0.52rem;
		color: var(--muted);
		font-size: 1rem;
		font-weight: 800;
		text-decoration: none;
		white-space: nowrap;
		transition:
			color 0.18s ease,
			transform 0.18s ease;
	}

	a::after {
		content: '';
		position: absolute;
		right: 0.08rem;
		bottom: 0.12rem;
		left: 0.08rem;
		height: 3px;
		border-radius: 999px;
		background: linear-gradient(90deg, #00c9aa, #62f3e1);
		opacity: 0;
		transform: scaleX(0.35);
		transition:
			opacity 0.18s ease,
			transform 0.18s ease;
	}

	a:hover,
	a.active {
		color: var(--text);
		transform: translateY(-1px);
	}

	a.active::after,
	a:hover::after {
		opacity: 1;
		transform: scaleX(1);
	}
</style>
