---
interface Props {
	date: Date;
	locale?: 'zh' | 'en';
}

const { date, locale = 'zh' } = Astro.props;
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale === 'en' ? 'en-US' : 'zh-CN', {
			year: 'numeric',
			month: locale === 'en' ? 'short' : 'long',
			day: 'numeric',
		})
	}
</time>
