---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostCode } from '../../blogVisuals';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const postOrder = [
	'scaling-social-account-operations',
	'spreadsheets-break-50',
	'real-social-ops-platform',
	'mcn-prove-value-with-data',
	'cloud-phone-vs-browser',
	'proxy-ip-types',
	'one-workflow-five-tools',
	'tiktok-risk-guide',
	'global-brand-scale',
	'localization-how-deep',
];
const posts = (await getCollection('blog', (entry) => !entry.data.draft && postOrder.includes(entry.id))).sort((a, b) => {
	const aOrder = postOrder.indexOf(a.id);
	const bOrder = postOrder.indexOf(b.id);
	return (aOrder === -1 ? 999 : aOrder) - (bOrder === -1 ? 999 : bOrder);
});
const featuredPost = posts[0];
const gridPosts = posts.slice(1);
const spanMap: Record<string, 'wide' | 'tall' | 'none'> = {
	'spreadsheets-break-50': 'tall',
	'real-social-ops-platform': 'wide',
	'tiktok-risk-guide': 'wide',
};
const categoryCounters: Record<string, number> = featuredPost ? { [featuredPost.data.category]: 1 } : {};
const nextCategoryIndex = (category: string) => {
	const value = categoryCounters[category] ?? 0;
	categoryCounters[category] = value + 1;
	return value;
};
const categoryOrder = ['运营方法论', '平台专题', '产品能力解读', '出海观察', '操作教程', '运营实践', '产品更新'];
const allCategoryLabels = new Set(posts.map((post) => post.data.category));
const categories = [
	'全部文章',
	...categoryOrder.filter((category) => allCategoryLabels.has(category)),
	...Array.from(allCategoryLabels).filter((category) => !categoryOrder.includes(category)),
];
const featuredCode = featuredPost ? getPostCode(featuredPost.data.category, 0) : 'OPS-01';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`博客文章 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="keyword-ticker" aria-hidden="true">
			<div class="ticker-track">
				<span>TIKTOK</span>
				<span>INSTAGRAM</span>
				<span>云手机环境</span>
				<span>代理 IP 管理</span>
				<span>批量任务发布</span>
				<span>素材库</span>
				<span>REDDIT</span>
				<span>X</span>
				<span>账号矩阵</span>
				<span>TIKTOK</span>
				<span>INSTAGRAM</span>
				<span>云手机环境</span>
				<span>代理 IP 管理</span>
				<span>批量任务发布</span>
				<span>素材库</span>
				<span>REDDIT</span>
				<span>X</span>
				<span>账号矩阵</span>
			</div>
		</div>
		<main>
			<section class="page-head">
				<span class="cursor-glow" aria-hidden="true"></span>
				<div class="page-head-copy">
					<span class="section-kicker">麦芽营销团队出品</span>
					<h1>当账号数量 从 1 变成 <em id="counter-num">1000+</em></h1>
					<p>写给需要在 TikTok、Instagram、Reddit 和 X 上管理成百上千个账号的代运营机构、MCN 和出海品牌团队。</p>
					<div class="hero-stats" aria-label="博客内容概览">
						<span><strong>04</strong>内容栏目</span>
						<span><strong>{posts.length}</strong>篇实战文章</span>
						<span><strong>4</strong>个主题</span>
					</div>
				</div>
				<div class="tile-visual" aria-hidden="true">
					<div class="console-card">
						<div class="console-dots"><span></span><span></span><span></span></div>
						<div class="console-line"><span id="console-text"></span><span class="console-cursor"></span></div>
					</div>
					<div class="tile-grid">
						{Array.from({ length: 42 }).map((_, index) => <span class:list={['tile', { bright: index % 8 === 0 || index % 13 === 0 }]} style={`--delay: ${(index % 11) * 0.18}s`} />)}
					</div>
				</div>
			</section>

			{
				featuredPost && (
					<section class="spotlight-card">
						<div class="spotlight-copy">
							<div class="article-code">
								<span>FEATURED</span>
								<span aria-hidden="true">/</span>
								<span>{featuredCode}</span>
							</div>
							<h2>
								<a href={`/blog/${featuredPost.id}/`}>{featuredPost.data.title}</a>
							</h2>
							<p>{featuredPost.data.description}</p>
						</div>
						<div class="spotlight-meta">
							<span><FormattedDate date={featuredPost.data.pubDate} /></span>
							<span>7 MIN</span>
							<a href={`/blog/${featuredPost.id}/`}>阅读全文 -&gt;</a>
						</div>
					</section>
				)
			}

			<section class="filter-bar" aria-label="文章分类筛选">
				{
					categories.map((category, index) => (
						<button class:list={['filter-pill', { selected: index === 0 }]} type="button" data-filter={category}>
							<span class="dot" aria-hidden="true"></span>
							{category}
						</button>
					))
				}
			</section>

			<section class="post-grid bento-grid" id="post-grid">
				{gridPosts.map((post) => <PostCard post={post} index={nextCategoryIndex(post.data.category)} variant="bento" span={spanMap[post.id] ?? 'none'} />)}
			</section>
		</main>
		<Footer />
		<script>
			const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
			const cards = document.querySelectorAll<HTMLElement>('#post-grid > [data-category]');

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					filterButtons.forEach((item) => item.classList.remove('selected'));
					button.classList.add('selected');
					const filter = button.dataset.filter;

					cards.forEach((card) => {
						const visible = filter === '全部文章' || card.dataset.category === filter;
						card.toggleAttribute('hidden', !visible);
					});
				});
			});

			const heroPanels = document.querySelectorAll<HTMLElement>('.page-head');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (supportsHover) {
				heroPanels.forEach((panel) => {
					panel.addEventListener('pointermove', (event) => {
						const rect = panel.getBoundingClientRect();
						panel.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
						panel.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerenter', () => {
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerleave', () => {
						panel.classList.remove('is-glowing');
					});
				});

				document.querySelectorAll<HTMLElement>('.post-card').forEach((card) => {
					card.addEventListener('pointermove', (event) => {
						const rect = card.getBoundingClientRect();
						const x = event.clientX - rect.left;
						const y = event.clientY - rect.top;
						const rotateX = ((y / rect.height) - 0.5) * -4;
						const rotateY = ((x / rect.width) - 0.5) * 4;
						card.style.setProperty('--glare-x', `${event.clientX - rect.left}px`);
						card.style.setProperty('--glare-y', `${event.clientY - rect.top}px`);
						if (card.classList.contains('bento')) {
							card.style.transform = `translateY(-4px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
						}
					});

					card.addEventListener('pointerleave', () => {
						card.style.transform = '';
					});
				});
			}

			const tileGrids = document.querySelectorAll<HTMLElement>('.tile-grid');
			window.addEventListener(
				'scroll',
				() => {
					const offset = Math.min(window.scrollY * 0.08, 34);
					tileGrids.forEach((grid) => {
						grid.style.transform = `translateY(${offset}px)`;
					});
				},
				{ passive: true },
			);

			const consoleLines = [
				'batch_publish(tiktok, accounts=42) ... 完成',
				'proxy_check(static_ip) ... 正常',
				'account_warmup(instagram, x38) ... 运行中',
				'task_queue: 309 已完成',
				'cloud_env(bind_device) ... 已同步',
			];
			const consoleText = document.getElementById('console-text');
			let lineIndex = 0;
			let charIndex = 0;
			let deleting = false;

			function typeConsoleLine() {
				if (!consoleText) return;
				const line = consoleLines[lineIndex];

				if (!deleting) {
					charIndex += 1;
					consoleText.textContent = line.slice(0, charIndex);
					if (charIndex >= line.length) {
						deleting = true;
						window.setTimeout(typeConsoleLine, 1400);
						return;
					}
					window.setTimeout(typeConsoleLine, 38);
					return;
				}

				charIndex -= 1;
				consoleText.textContent = line.slice(0, charIndex);
				if (charIndex <= 0) {
					deleting = false;
					lineIndex = (lineIndex + 1) % consoleLines.length;
					window.setTimeout(typeConsoleLine, 300);
					return;
				}
				window.setTimeout(typeConsoleLine, 16);
			}

			typeConsoleLine();

			const counter = document.getElementById('counter-num');
			if (counter && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				let value = 1;
				const step = () => {
					value = Math.min(1000, value + Math.ceil((1000 - value) / 9));
					counter.textContent = `${value}+`;
					if (value < 1000) {
						window.requestAnimationFrame(step);
					}
				};
				window.requestAnimationFrame(step);
			}
		</script>
	</body>
</html>

<style>
	.keyword-ticker {
		overflow: hidden;
		border-bottom: 1px solid rgba(6, 39, 42, 14%);
		background: #06272a;
		color: #d8fffa;
	}

	.ticker-track {
		display: flex;
		width: max-content;
		gap: 2rem;
		padding: 0.45rem 0;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.76rem;
		font-weight: 800;
		letter-spacing: 0.11em;
		animation: ticker-slide 34s linear infinite;
	}

	.ticker-track span {
		position: relative;
		white-space: nowrap;
		opacity: 0.86;
	}

	.ticker-track span::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1.15rem;
		width: 0.28rem;
		height: 0.28rem;
		border-radius: 999px;
		background: var(--accent);
		transform: translateY(-50%);
	}

	@keyframes ticker-slide {
		to {
			transform: translateX(-50%);
		}
	}

	.page-head {
		--glow-x: 50%;
		--glow-y: 50%;
		position: relative;
		isolation: isolate;
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(260px, 0.92fr);
		gap: 2rem;
		align-items: center;
		margin-bottom: 1.35rem;
		overflow: hidden;
		padding: clamp(2rem, 5vw, 4rem);
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(0, 201, 170, 12%), rgba(0, 69, 76, 6%)),
			white;
		box-shadow: var(--shadow);
	}

	.cursor-glow {
		position: absolute;
		z-index: 0;
		inset: -12%;
		background: radial-gradient(
			circle 260px at var(--glow-x) var(--glow-y),
			rgba(46, 233, 208, 38%),
			rgba(0, 201, 170, 16%) 34%,
			rgba(0, 125, 118, 8%) 48%,
			transparent 72%
		);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.page-head.is-glowing .cursor-glow {
		opacity: 1;
	}

	.page-head-copy {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1rem;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.page-head p {
		max-width: 720px;
		font-size: 1.05rem;
	}

	.page-head h1 em {
		color: var(--accent-dark);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-style: normal;
	}

	.hero-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 0.25rem;
		color: var(--muted);
		font-weight: 800;
	}

	.hero-stats span {
		border: 1px solid rgba(0, 201, 170, 28%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 70%);
		padding: 0.45rem 0.75rem;
	}

	.hero-stats strong {
		margin-right: 0.2rem;
		color: var(--text);
	}

	.tile-visual {
		position: relative;
		z-index: 1;
	}

	.tile-grid {
		position: relative;
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		gap: 0.55rem;
		transition: transform 0.12s linear;
	}

	.console-card {
		position: absolute;
		top: -0.55rem;
		right: 0.35rem;
		z-index: 2;
		width: min(250px, 74%);
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 8px;
		background: linear-gradient(135deg, #052e2b, #073b37);
		padding: 0.85rem 1rem;
		box-shadow: 0 22px 44px -18px rgba(6, 39, 42, 55%);
	}

	.console-dots {
		display: flex;
		gap: 0.35rem;
		margin-bottom: 0.6rem;
	}

	.console-dots span {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 22%);
	}

	.console-line {
		min-height: 1.1rem;
		overflow: hidden;
		color: var(--accent);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.72rem;
		font-weight: 800;
		white-space: nowrap;
	}

	.console-cursor {
		display: inline-block;
		width: 0.4rem;
		height: 0.85rem;
		margin-left: 0.15rem;
		background: var(--accent);
		vertical-align: -0.08rem;
		animation: console-blink 0.9s step-end infinite;
	}

	@keyframes console-blink {
		50% {
			opacity: 0;
		}
	}

	.tile {
		aspect-ratio: 1;
		border-radius: 7px;
		background: rgba(0, 177, 179, 10%);
		animation: tile-breathe 4.8s ease-in-out var(--delay) infinite;
	}

	.tile.bright {
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		box-shadow: 0 10px 28px rgba(0, 201, 170, 24%);
	}

	@keyframes tile-breathe {
		0%,
		100% {
			opacity: 0.42;
			transform: scale(0.94);
		}

		45% {
			opacity: 1;
			transform: scale(1);
		}
	}

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		align-items: center;
		margin-bottom: 1rem;
	}

	.spotlight-card {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1rem;
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(6, 39, 42, 92%), rgba(4, 63, 60, 88%)),
			white;
		padding: clamp(1.3rem, 3vw, 2rem);
		box-shadow: var(--shadow);
	}

	.spotlight-card::before {
		content: '';
		position: absolute;
		inset: auto 8% -35% auto;
		width: 16rem;
		height: 16rem;
		border-radius: 999px;
		background: rgba(46, 233, 208, 18%);
		filter: blur(30px);
	}

	.spotlight-copy,
	.spotlight-meta {
		position: relative;
		z-index: 1;
	}

	.spotlight-copy {
		display: grid;
		gap: 0.85rem;
	}

	.spotlight-copy .article-code {
		display: inline-flex;
		gap: 0.5rem;
		align-items: center;
		width: fit-content;
		border: 1px solid rgba(46, 233, 208, 36%);
		border-radius: 999px;
		background: rgba(227, 251, 247, 10%);
		padding: 0.3rem 0.7rem;
		color: #72f7e8;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.spotlight-card h2 {
		max-width: 780px;
		font-size: clamp(1.5rem, 3vw, 2.45rem);
	}

	.spotlight-card h2 a {
		color: white;
		text-decoration: none;
	}

	.spotlight-card p {
		max-width: 780px;
		color: #b8eee7;
	}

	.spotlight-meta {
		display: grid;
		gap: 0.55rem;
		justify-items: end;
		color: #d8fffa;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 900;
		white-space: nowrap;
	}

	.spotlight-meta a {
		color: var(--accent);
		text-decoration: none;
	}

	.filter-pill {
		display: inline-flex;
		gap: 0.45rem;
		align-items: center;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: white;
		padding: 0.55rem 0.9rem;
		color: var(--muted);
		font: inherit;
		font-weight: 800;
		cursor: pointer;
	}

	.filter-pill .dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: currentColor;
		opacity: 0.45;
	}

	.filter-pill:hover,
	.filter-pill.selected {
		border-color: var(--accent-dark);
		background: #063f3c;
		color: white;
	}

	.filter-pill.selected .dot {
		opacity: 1;
	}

	@media (max-width: 900px) {
		.page-head {
			grid-template-columns: 1fr;
		}

		.spotlight-card {
			grid-template-columns: 1fr;
		}

		.spotlight-meta {
			justify-items: start;
		}

		.tile-visual {
			display: none;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.cursor-glow {
			display: none;
		}
	}
</style>
